# Supabase (required for full auth and DB-backed projects/answers)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Set to "true" to enforce Supabase login via middleware.
# Leaving this unset keeps the app in legacy/password mode and avoids per-request auth refresh overhead.
# SUPABASE_AUTH_ENABLED=true

# OpenAI (for Design Concept: style reasoning + summary blocks)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: base path if app is served under a subpath
# NEXT_PUBLIC_BASE_PATH=

# Legacy: only used when Supabase is NOT configured (single shared password)
# ADMIN_PASSWORD=
